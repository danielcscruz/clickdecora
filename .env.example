# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_PASSWORD=clickdecora_dev

# ─────────────────────────────────────────────
# Backend (FastAPI)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clickdecora:clickdecora_dev@localhost:5434/clickdecora
SECRET_KEY=your_256bit_secret_key_here
ALGORITHM=HS256

# Mercado Pago — NUNCA expor no cliente
MP_ACCESS_TOKEN=APP_USR-your-access-token
MP_WEBHOOK_SECRET=your_webhook_hmac_secret
# URL pública para receber notificações do MP (usar ngrok em dev)
MP_NOTIFICATION_URL=

# CORS — domínio(s) do frontend separados por vírgula
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# Frontend (Next.js)
# ATENÇÃO: NENHUMA variável com segredo usa NEXT_PUBLIC_
# ─────────────────────────────────────────────
NEXTAUTH_SECRET=your_nextauth_secret_32chars_min
NEXTAUTH_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# URL interna da API FastAPI (server-side only)
BACKEND_URL=http://localhost:8000

# Calendly — URL pública do evento de agendamento
CALENDLY_URL=https://calendly.com/your-event-url
